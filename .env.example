# ─────────────────────────────────────────────────────────────────────────────
#  Pro-Rooms Backend — Environment Variables
#  Copy this to .env and fill in your real values.
# ─────────────────────────────────────────────────────────────────────────────

# Flask core
SECRET_KEY=change-me-to-a-random-secret

# JWT (for React auth)
JWT_SECRET_KEY=change-me-to-another-random-secret

# PostgreSQL database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=rooms_db

# Google OAuth (optional — Google Login will be disabled if missing)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# CORS — comma-separated list of allowed React origins
CORS_ORIGINS=http://localhost:5173
